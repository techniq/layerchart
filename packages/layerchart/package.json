{
  "name": "layerchart",
  "description": "Composable Svelte chart components to build a wide range of visualizations",
  "author": "Sean Lynch <techniq35@gmail.com>",
  "license": "MIT",
  "repository": "techniq/layerchart",
  "homepage": "https://layerchart.com",
  "version": "2.0.0-next.49",
  "scripts": {
    "dev": "pnpm package:watch",
    "package": "svelte-package",
    "package:watch": "svelte-package --watch",
    "prepublishOnly": "svelte-package",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "test:unit": "TZ=UTC-5 vitest",
    "test:ui": "TZ=UTC-5 vitest --ui",
    "bench": "pnpm bench:primitives && pnpm bench:linechart && pnpm bench:composable && pnpm bench:svg-vs-canvas",
    "bench:primitives": "TZ=UTC-5 vitest bench --project bench src/lib/bench/primitives.svelte.bench.ts",
    "bench:linechart": "TZ=UTC-5 vitest bench --project bench src/lib/components/charts/LineChart.svelte.bench.ts",
    "bench:composable": "TZ=UTC-5 vitest bench --project bench src/lib/bench/composable-vs-linechart.svelte.bench.ts",
    "bench:svg-vs-canvas": "TZ=UTC-5 vitest bench --project bench src/lib/bench/svg-vs-canvas.svelte.bench.ts",
    "bench:save": "TZ=UTC-5 vitest bench --project bench --outputJson bench-results/latest.json",
    "bench:compare": "TZ=UTC-5 vitest bench --project bench --compare bench-results/latest.json",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "prepare": "svelte-kit sync"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@svitejs/changesets-changelog-github-compact": "^1.2.0",
    "@types/d3": "^7.4.3",
    "@types/d3-array": "^3.2.2",
    "@types/d3-chord": "^3.0.6",
    "@types/d3-color": "^3.1.3",
    "@types/d3-delaunay": "^6.0.4",
    "@types/d3-dsv": "^3.0.7",
    "@types/d3-force": "^3.0.10",
    "@types/d3-geo": "^3.1.0",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/d3-interpolate": "^3.0.4",
    "@types/d3-interpolate-path": "^2.0.3",
    "@types/d3-path": "^3.1.1",
    "@types/d3-quadtree": "^3.0.6",
    "@types/d3-random": "^3.0.3",
    "@types/d3-sankey": "^0.12.5",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-scale-chromatic": "^3.1.0",
    "@types/d3-shape": "^3.1.8",
    "@types/d3-time": "^3.0.4",
    "@vitest/browser": "^4.1.0",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "5.54.1",
    "svelte-check": "^4.4.5",
    "svelte2tsx": "^0.7.52",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.0",
    "vitest-browser-svelte": "^2.1.0"
  },
  "type": "module",
  "dependencies": {
    "@dagrejs/dagre": "^2.0.4",
    "@layerstack/svelte-actions": "1.0.1-next.18",
    "@layerstack/svelte-state": "0.1.0-next.23",
    "@layerstack/tailwind": "2.0.0-next.21",
    "@layerstack/utils": "2.0.0-next.18",
    "@types/d3-contour": "^3.0.6",
    "d3-array": "^3.2.4",
    "d3-chord": "^3.0.1",
    "d3-color": "^3.1.0",
    "d3-contour": "^4.0.2",
    "d3-delaunay": "^6.0.4",
    "d3-dsv": "^3.0.1",
    "d3-force": "^3.0.0",
    "d3-geo": "^3.1.1",
    "d3-geo-voronoi": "^2.1.0",
    "d3-hierarchy": "^3.1.2",
    "d3-interpolate": "^3.0.1",
    "d3-interpolate-path": "^2.3.0",
    "d3-path": "^3.1.0",
    "d3-quadtree": "^3.0.1",
    "d3-random": "^3.0.1",
    "d3-sankey": "^0.12.3",
    "d3-scale": "^4.0.2",
    "d3-scale-chromatic": "^3.1.0",
    "d3-shape": "^3.2.0",
    "d3-tile": "^1.0.0",
    "d3-time": "^3.1.0",
    "memoize": "^10.2.0",
    "runed": "^0.37.1"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./utils/*": {
      "types": "./dist/utils/*.d.ts",
      "svelte": "./dist/utils/*.js",
      "default": "./dist/utils/*.js"
    },
    "./*.css": {
      "style": "./dist/styles/*.css",
      "default": "./dist/styles/*.css"
    }
  },
  "files": [
    "dist"
  ],
  "svelte": "./dist/index.js"
}
