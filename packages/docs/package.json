{
	"name": "@layerstack/docs",
	"description": "Reusable documentation tooling and components for LayerStack projects",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"check": "svelte-check --workspace ./src --tsconfig ../tsconfig.json",
		"package": "svelte-package",
		"build": "svelte-package",
		"lint": "prettier --check .",
		"format": "prettier --write .",
		"prepare": "svelte-kit sync"
	},
	"bin": {
		"layerstack-docs": "./bin/layerstack-docs.js"
	},
	"exports": {
		".": {
			"types": "./src/lib/index.ts",
			"svelte": "./src/lib/index.ts",
			"default": "./src/lib/index.ts"
		},
		"./api": {
			"types": "./src/lib/api-types.ts",
			"default": "./src/lib/api-types.ts"
		},
		"./catalog": {
			"types": "./src/lib/catalog.ts",
			"default": "./src/lib/catalog.ts"
		},
		"./collections": {
			"types": "./src/lib/collections.ts",
			"default": "./src/lib/collections.ts"
		},
		"./components": {
			"types": "./src/lib/components/index.ts",
			"svelte": "./src/lib/components/index.ts",
			"default": "./src/lib/components/index.ts"
		},
		"./components/*": {
			"svelte": "./src/lib/components/*",
			"default": "./src/lib/components/*"
		},
		"./styles.css": {
			"default": "./src/styles.css"
		},
		"./content": {
			"types": "./src/lib/content.ts",
			"default": "./src/lib/content.js"
		},
		"./content-collections": {
			"types": "./src/lib/content-collections/index.ts",
			"default": "./src/lib/content-collections/index.js"
		},
		"./context": {
			"types": "./src/lib/context.ts",
			"default": "./src/lib/context.ts"
		},
		"./examples": {
			"types": "./src/lib/examples.ts",
			"default": "./src/lib/examples.ts"
		},
		"./examples-glob": {
			"types": "./src/lib/examples-glob.ts",
			"default": "./src/lib/examples-glob.ts"
		},
		"./page-transitions": {
			"types": "./src/lib/page-transitions.ts",
			"default": "./src/lib/page-transitions.ts"
		},
		"./project-stats": {
			"types": "./src/lib/project-stats.ts",
			"default": "./src/lib/project-stats.ts"
		},
		"./markdown": {
			"types": "./src/lib/markdown/index.ts",
			"default": "./src/lib/markdown/index.js"
		},
		"./markdown/config": {
			"default": "./src/lib/markdown/config/index.js"
		},
		"./markdown/rehype/live-code": {
			"default": "./src/lib/markdown/rehype/live-code.js"
		},
		"./markdown/components": {
			"types": "./src/lib/markdown/components/index.ts",
			"svelte": "./src/lib/markdown/components/index.ts",
			"default": "./src/lib/markdown/components/index.ts"
		},
		"./markdown/components/*": {
			"svelte": "./src/lib/markdown/components/*",
			"default": "./src/lib/markdown/components/*"
		},
		"./markdown/blueprints/default/blueprint.svelte": {
			"svelte": "./src/lib/markdown/blueprints/default/blueprint.svelte",
			"default": "./src/lib/markdown/blueprints/default/blueprint.svelte"
		},
		"./node/stackblitz": {
			"types": "./src/lib/node/stackblitz.ts",
			"default": "./src/lib/node/stackblitz.ts"
		},
		"./node/component-api": {
			"types": "./src/lib/node/component-api.ts",
			"default": "./src/lib/node/component-api.ts"
		},
		"./node/example-catalog": {
			"types": "./src/lib/node/example-catalog.ts",
			"default": "./src/lib/node/example-catalog.ts"
		},
		"./node/screenshots": {
			"types": "./src/lib/node/screenshots.ts",
			"default": "./src/lib/node/screenshots.ts"
		},
		"./node/releases": {
			"types": "./src/lib/node/releases.ts",
			"default": "./src/lib/node/releases.ts"
		}
	},
	"files": [
		"README.md",
		"bin",
		"src",
		"templates",
		"dist"
	],
	"peerDependencies": {
		"@sveltejs/kit": "^2.0.0",
		"svelte": "^5.0.0"
	},
	"dependencies": {
		"@layerstack/tailwind": "2.0.0-next.21",
		"@layerstack/utils": "2.0.0-next.18",
		"@shikijs/transformers": "^4.0.2",
		"@content-collections/core": "^0.14.3",
		"@content-collections/markdown": "^0.1.4",
		"@webcontainer/api": "^1.6.1",
		"@sveltejs/svelte-json-tree": "^2.2.1",
		"github-slugger": "^2.0.0",
		"mdsx": "^0.0.7",
		"playwright": "^1.59.1",
		"rehype-pretty-code": "^0.14.3",
		"rehype-slug": "^6.0.0",
		"remark-gfm": "^4.0.1",
		"remark-mdc": "^3.10.0",
		"runed": "^0.37.1",
		"sharp": "^0.34.5",
		"shiki": "^4.0.2",
		"svelte-ux": "2.0.0-next.22",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"unist-builder": "^4.0.0",
		"unist-util-visit": "^5.1.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"prettier": "^3.8.2",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "5.55.3",
		"svelte-check": "^4.4.6",
		"unplugin-icons": "^23.0.1",
		"vite": "^8.0.8",
		"vitest": "^4.1.4"
	},
	"svelte": "./src/lib/index.ts"
}
