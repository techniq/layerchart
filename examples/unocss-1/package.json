		"@unocss/preset-wind4": "^66.6.7",
		"@unocss/svelte-scoped": "^66.6.7",
		"layerchart": "workspace:*",
		"mode-watcher": "^1.1.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "5.54.1",
		"svelte-check": "^4.4.5",
		"typescript": "^5.9.3",
		"unocss": "^66.6.7",
		"vite": "^7.0.0",
		"vite-plugin-devtools-json": "^1.0.0"
	}
